# Placeholder values only. Do not commit real secrets.

NODE_ENV=development
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql://hoa_app:CHANGE_ME@localhost:5432/hoa_billing?schema=public
DATABASE_MIGRATION_URL=postgresql://hoa_migration:CHANGE_ME@localhost:5432/hoa_billing?schema=public
DATABASE_BACKUP_URL=postgresql://hoa_backup:CHANGE_ME@localhost:5432/hoa_billing?schema=public
DATABASE_SSL_MODE=disable

SESSION_SECRET_FILE=/run/secrets/session_secret
MFA_ENCRYPTION_KEY_FILE=/run/secrets/mfa_encryption_key
CSRF_SECRET_FILE=/run/secrets/csrf_secret
BACKUP_ENCRYPTION_KEY_FILE=/run/secrets/backup_encryption_key

COOKIE_NAME=hoa_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
PRIVILEGED_IDLE_TIMEOUT_MINUTES=15
PRIVILEGED_ABSOLUTE_TIMEOUT_HOURS=8
STANDARD_IDLE_TIMEOUT_MINUTES=60
STANDARD_ABSOLUTE_TIMEOUT_HOURS=24

PBT_SEED=
